# 强制 GitHub 语言统计以 Java 为主语言
# Maven POM
pom.xml linguist-language=Java linguist-generated=false
**/pom.xml linguist-language=Java linguist-generated=false

# Spring Boot 配置文件 → 归类为 Java 附属
*.properties linguist-language=Java linguist-vendored=false
*.yml linguist-language=Java linguist-vendored=false
*.yaml linguist-language=Java linguist-vendored=false

# MyBatis Mapper XML
**/mapper/*.xml linguist-language=Java linguist-vendored=false

# Spring 配置 XML
**/logback-spring.xml linguist-language=Java linguist-vendored=false

# SQL 脚本 → 项目附属
*.sql linguist-vendored

# 项目文档
*.md linguist-documentation

# Gradle（如未来迁移）
*.gradle linguist-language=Java linguist-vendored=false

# 前端 / 静态资源（不计入语言统计）
*.html linguist-generated
*.css linguist-generated
*.js linguist-generated
*.vue linguist-generated
*.json linguist-generated

# 图片 / 字体（不计入语言统计）
*.png linguist-generated
*.jpg linguist-generated
*.jpeg linguist-generated
*.gif linguist-generated
*.svg linguist-generated
*.eot linguist-generated
*.ttf linguist-generated
*.woff linguist-generated
*.woff2 linguist-generated
*.ico linguist-generated

# IDE 配置
.idea/** linguist-generated
*.iml linguist-generated
*.iws linguist-generated
*.ipr linguist-generated
